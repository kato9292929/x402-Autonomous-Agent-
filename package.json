{
  "name": "x402-autonomous-agent",
  "version": "1.0.0",
  "description": "Autonomous trading agent using x402 payment protocol",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node src/index.ts",
    "run-now": "ts-node src/index.ts --run-now",
    "verify-products": "ts-node src/scripts/verify-products.ts",
    "test": "npm run build && node --test dist/__tests__/**/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@solana/kit": "^6.9.0",
    "@types/node": "22.10.7",
    "@types/node-cron": "3.0.11",
    "@worldcoin/idkit-core": "^4.1.8",
    "@x402/core": "^2.13.0",
    "@x402/evm": "^2.13.0",
    "@x402/fetch": "^2.13.0",
    "@x402/svm": "^2.15.0",
    "dotenv": "16.4.7",
    "node-cron": "3.0.3",
    "qrcode": "^1.5.4",
    "typescript": "5.7.3"
  },
  "devDependencies": {
    "@types/node-cron": "3.0.11",
    "@types/qrcode": "^1.5.6",
    "ts-node": "10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
