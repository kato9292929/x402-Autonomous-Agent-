{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "api/run.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/run",
      "dest": "/api/run.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/run",
      "schedule": "0 21 * * *"
    }
  ]
}
