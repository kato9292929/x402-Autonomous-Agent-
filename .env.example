# ───────────────────────────────────────────────────────────────
# 署名バックエンド: Circle Developer-Controlled Wallets (推奨)
# ───────────────────────────────────────────────────────────────
# SIGNER_BACKEND: "circle" | "privatekey" (未設定時は Circle 認証情報があれば circle)
SIGNER_BACKEND=circle

# Circle Developer Console の認証情報 (絶対にコミットしない)
CIRCLE_API_KEY=            # Circle Developer Console の API キー
CIRCLE_ENTITY_SECRET=      # 32バイト hex の Entity Secret (npm run circle:register で登録)
# CIRCLE_BASE_URL=         # 任意: API ベース URL の上書き

# Circle ウォレット (npm run circle:setup で作成 → 出力値を貼り付け)
CIRCLE_WALLET_SET_ID=
CIRCLE_EVM_WALLET_ID=
CIRCLE_EVM_WALLET_ADDRESS=
CIRCLE_SOLANA_WALLET_ID=
CIRCLE_SOLANA_WALLET_ADDRESS=

# spending controls (Circle Wallet 経由の支払いを AA 側で enforce)
CIRCLE_PER_TX_LIMIT_USD=5    # 1トランザクションあたり上限 (USD)
CIRCLE_DAILY_LIMIT_USD=20    # 1日あたり上限 (USD, UTC基準)
CIRCLE_ALLOWLIST=            # カンマ区切りの payTo アドレス allowlist (空=全許可)

# テストネット検証用 (任意): Base Sepolia の x402 エンドポイント
TEST_URL=

# ───────────────────────────────────────────────────────────────
# レガシー署名 (Circle 未設定時のフォールバック)
# ───────────────────────────────────────────────────────────────
# x402マイクロペイメント用EOAウォレット（秘密鍵）
PAYMENT_PRIVATE_KEY=  # 0xで始まる64桁の16進数秘密鍵 (USDCをBase mainnetで保有すること)

# Anthropic
ANTHROPIC_API_KEY=

# Portfolio Intelligence — 分析対象ウォレットアドレス
PORTFOLIO_ANALYZE_TARGET=  # 例: 0x...

# モードB エンドポイント URL overrides (任意 — 未設定時はデフォルト値を使用)
APAC_MACRO_URL=
YIELD_INTELLIGENCE_URL=
PORTFOLIO_INTELLIGENCE_URL=
JAPAN_REAL_ESTATE_URL=
DIVERGENCE_ANALYZER_URL=
HYPERLIQUID_INTELLIGENCE_URL=
PRIVATE_MARKET_URL=
SMART_MONEY_SCREENER_URL=
ONCHAIN_FEED_APAC_URL=
ONCHAIN_FEED_WHALE_URL=

# モードC エンドポイント URL overrides (任意)
APAC_MACRO_WEEKLY_URL=
YIELD_INTELLIGENCE_WEEKLY_URL=
JAPAN_REAL_ESTATE_WEEKLY_URL=
ALPHA_MEMO_WEEKLY_URL=
ONCHAIN_FEED_WEEKLY_URL=

# analyst-daily-note ジョブ
INTERNAL_API_KEY=         # Onchain Stock Data 側と同じ値
ANALYST_API_BASE=https://osd-coral.vercel.app
NOTE_API_KEY=             # 任意: note.com 投稿する場合

# 通知 webhook (任意)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
