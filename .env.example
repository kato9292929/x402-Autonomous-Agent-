# Coinbase Developer Platform
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
WALLET_DATA=          # JSON文字列。初回起動後にwalletDataをここに保存して永続化

# x402マイクロペイメント用EOAウォレット（秘密鍵）
# CDPウォレットは秘密鍵を公開しないため、x402署名には別途EOAが必要
PAYMENT_PRIVATE_KEY=  # 0xで始まる64桁の16進数秘密鍵 (USDCを十分保有すること)

# EVM受取ウォレット (x402決済受け取り用 — AgentKitウォレットとは別)
WALLET_ADDRESS=       # 0xで始まるEVMアドレス

# Solana受取ウォレット
SOLANA_WALLET_ADDRESS=

# Anthropic
ANTHROPIC_API_KEY=

# X (Twitter) API
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# CDP Facilitator
FACILITATOR_URL=https://api.developer.coinbase.com/rpc/v1/base/facilitator
