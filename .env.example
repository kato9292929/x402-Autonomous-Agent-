# Base(EVM) 署名バックエンド: circle = Circle DCW で署名(本番) / privatekey = ローカル EOA(既定)
SIGNER_BACKEND=            # circle | privatekey (未設定時は privatekey)

# x402マイクロペイメント用EOAウォレット（秘密鍵。SIGNER_BACKEND=privatekey のとき必須）
PAYMENT_PRIVATE_KEY=  # 0xで始まる64桁の16進数秘密鍵 (USDCをBase mainnetで保有すること)

# Circle DCW EVM ウォレット (SIGNER_BACKEND=circle のとき Base 決済の署名に使用)
CIRCLE_EVM_WALLET_ID=       # Circle console で確認
CIRCLE_EVM_WALLET_ADDRESS=  # 0x... (Base mainnet の USDC を保有すること)

# Anthropic
ANTHROPIC_API_KEY=

# Portfolio Intelligence — 分析対象ウォレットアドレス
PORTFOLIO_ANALYZE_TARGET=  # 例: 0x...

# モードB エンドポイント URL overrides (任意 — 未設定時はデフォルト値を使用)
APAC_MACRO_URL=
YIELD_INTELLIGENCE_URL=
PORTFOLIO_INTELLIGENCE_URL=
JAPAN_REAL_ESTATE_URL=
DIVERGENCE_ANALYZER_URL=
HYPERLIQUID_INTELLIGENCE_URL=
PRIVATE_MARKET_URL=
SMART_MONEY_SCREENER_URL=
ONCHAIN_FEED_APAC_URL=
ONCHAIN_FEED_WHALE_URL=

# モードA 日次判断ループ
WHALE_INTENT_DECODER_URL=     # 任意: 未設定時は https://x402wid.vercel.app/api/decode
ERC8004_AGENT_ID=             # 日次 call を紐付ける ERC-8004 agentId (未設定時は 55560)

# モードA 判断記録ストア (Upstash Redis REST。未設定時はローカル JSONL のみに追記)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# モードC エンドポイント URL overrides (任意)
APAC_MACRO_WEEKLY_URL=
YIELD_INTELLIGENCE_WEEKLY_URL=
JAPAN_REAL_ESTATE_WEEKLY_URL=
ALPHA_MEMO_WEEKLY_URL=
ONCHAIN_FEED_WEEKLY_URL=

# osd consumption ジョブ (Phase A 往復 ＋ 有料データ消費)
OSD_API_BASE=https://osd-coral.vercel.app   # 任意: 叩き先 base_url
OSD_DATA_SPEND_CAP_USD=0.20                  # 1 run の有料データ上限 (predict は別枠)
OSD_SUBMIT_MAX_PER_RUN=1                     # 1 run の catalyst submit 件数 (IP レート制限対策)
OSD_DATA_TICKERS_PER_RUN=1                   # stocks/{ticker} を叩く銘柄数/run
OSD_PREMIUM_WEEKLY_DAY=1                     # predict quick を叩く曜日 (UTC, 0=日 1=月)

# Mode D — osd alpha/track-record 消費 (Solana USDC per-call, x402)
OSD_API_BASE=https://osd-coral.vercel.app   # 任意: ALPHA_* 未設定時の base
ALPHA_US_PORTFOLIO_URL=   # 既定: {OSD_API_BASE}/api/alpha/portfolio/current
ALPHA_US_SCORECARD_URL=   # 既定: {OSD_API_BASE}/api/alpha/portfolio/scorecard
ALPHA_JP_PORTFOLIO_URL=   # 既定: {OSD_API_BASE}/api/alpha/jp/portfolio/current
ALPHA_JP_SCORECARD_URL=   # 既定: {OSD_API_BASE}/api/alpha/jp/scorecard
ALPHA_JP_CATALYSTS_URL=   # 既定: {OSD_API_BASE}/api/alpha/jp/catalysts

# ── Solana / Circle DCW ───────────────────────────────────────────────────────
# Circle Developer-Controlled Wallets API key
CIRCLE_API_KEY=

# Circle entity secret (32バイトの hex 文字列。Circle dashboard で生成・登録したもの)
CIRCLE_ENTITY_SECRET=

# Solana 決済レグの署名鍵 (base58 の 64byte keypair。未設定なら Solana endpoint はスキップ)
SOLANA_PRIVATE_KEY=

# Circle が発行した Solana wallet ID / address（Circle DCW での Solana 署名・PoC 用）
CIRCLE_SOLANA_WALLET_ID=
CIRCLE_SOLANA_WALLET_ADDRESS=

# LIVE の wallet set ID（circle-create-solana-wallet 用。Arc(TESTNET)では使わない）
CIRCLE_WALLET_SET_ID=

# Solana wallet address（Circle console で確認。表示・スクリプト用）
SOLANA_WALLET_ADDRESS=

# Hyre / PayAI endpoint URL overrides (任意 — 未設定時は TODO URL を使用)
HYRE_DEFI_INTELLIGENCE_URL=
HYRE_MARKET_SIGNALS_URL=

# Phase 1 外部データ wrappers (任意 — 未設定時はデフォルト URL を使用)
BIRDEYE_OHLCV_URL=

# World ID (Mode C の人間承認。RP signature / proof 検証に必須)
WLD_APP_ID=                 # app_... (World Developer Portal)
WLD_RP_ID=                  # rp_... (Relying Party ID)
WLD_SIGNING_KEY=            # RP signing key (hex)

# HTTP サーバー (Railway が自動で設定)
PORT=3000

# 通知 webhook (任意)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── Arc Testnet ERC-8004 identity 登録 (独立スクリプト。AA 本体の cron には未接続) ──────
# Arc は Circle TEST キーを使う(AA 本体の LIVE 認証 CIRCLE_API_KEY/CIRCLE_ENTITY_SECRET とは別)。
# LIVE キーだと testnet で HTTP 400 / code 156006 になるため TEST キー必須。LIVE は上書きしない。
CIRCLE_API_KEY_TEST=             # Circle Console の Testnet で発行した TEST_API_KEY
CIRCLE_ENTITY_SECRET_TEST=       # Testnet 環境用の entity secret
# ウォレット作成(arc:create-wallets)。TEST 環境の wallet set。未設定なら初回実行時に新規作成し
# CIRCLE_WALLET_SET_ID_TEST=... をログに出す(控えれば次回以降は再作成しない)。LIVE の
# CIRCLE_WALLET_SET_ID は使わない(TEST キーからは見えず 156005 になるため)。
CIRCLE_WALLET_SET_ID_TEST=       # 任意。未設定なら arc:create-wallets が新規作成
# arc:create-wallets の出力を設定(register に必要)
CIRCLE_ARC_OWNER_WALLET_ID=      # Arc Testnet owner ウォレット(identity 登録・validation request)
CIRCLE_ARC_VALIDATOR_WALLET_ID=  # validator ウォレット(reputation 記録・validation response)
ARC_OWNER_ADDRESS=               # 記録用(表示のみ)
ARC_VALIDATOR_ADDRESS=           # validationRequest の validatorAddress 引数に使う
# 任意
ARC_AGENT_ID=                    # 未指定なら M0 記録の arc_agent_id(=845265)
ARC_METADATA_URI=               # ipfs:// 形式。未指定ならチュートリアルの例 IPFS URI で疎通確認
ARC_TESTNET_RPC=                # 未指定なら https://rpc.testnet.arc.network/
