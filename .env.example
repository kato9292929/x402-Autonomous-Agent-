# x402マイクロペイメント用EOAウォレット（秘密鍵）
PAYMENT_PRIVATE_KEY=  # 0xで始まる64桁の16進数秘密鍵 (USDCをBase mainnetで保有すること)

# Anthropic
ANTHROPIC_API_KEY=

# Mode B — Portfolio Intelligence の分析対象ウォレット
PORTFOLIO_ANALYZE_TARGET=  # 分析したいウォレットアドレス (例: 0x...)

# Mode B — API URL overrides (デフォルト値あり。独自URLがある場合のみ設定)
APAC_MACRO_URL=         # default: https://x402macro.vercel.app
YIELD_INTEL_URL=        # default: https://x402yield.vercel.app
PORTFOLIO_INTEL_URL=    # default: https://x402portfolio.vercel.app
HYPERLIQUID_INTEL_URL=  # default: https://x402hyperliquid.vercel.app
X402_ORACLE_URL=        # default: https://x402oracle.vercel.app

# 通知 webhook (任意)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
